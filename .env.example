# GitHub
GITHUB_TOKEN=your_github_pat_here
GITHUB_USERNAME=your_github_username
GITHUB_REPO=https://github.com/your-username/elastic-hackathon

# Elastic Cloud / Elasticsearch
ELASTIC_CLOUD_ID=your_cloud_id_here
ELASTIC_API_KEY=your_api_key_here
ELASTICSEARCH_URL=https://your-deployment.es.cloud.es.io:9243

# Kibana (for Agent Builder API)
KIBANA_URL=https://your-deployment.kb.cloud.es.io:9243

# Elastic APM (optional — for observability)
ELASTIC_APM_SERVER_URL=https://your-apm-server.apm.cloud.es.io:443
ELASTIC_APM_SECRET_TOKEN=your_apm_token_here
